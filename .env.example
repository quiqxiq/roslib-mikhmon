# roslib-mikhmon environment

# === Database (PostgreSQL) ===
# Sesuaikan dengan service postgres di docker-compose.yml
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mikhmon
DB_USER=mikhmon
DB_PASSWORD=secret
DB_SSLMODE=disable

# === InfluxDB3 (historical data) ===
# Jalankan: docker compose up -d influxdb3
# --without-auth = tidak perlu token (dev mode)
INFLUX_ENABLED=true
INFLUX_HOST=http://localhost:8181
INFLUX_TOKEN=
INFLUX_DATABASE=mikhmon

# === HTTP server ===
HTTP_BIND=127.0.0.1:8080
HTTP_READ_TIMEOUT=10s
HTTP_IDLE_TIMEOUT=60s
HTTP_SHUTDOWN_GRACE=10s
# Production: lock ke origin tertentu, mis. "https://dashboard.example.com"
CORS_ALLOWED_ORIGINS=*

# === Integration test ===
# Prefix untuk resource yang dibuat saat test (mudah cleanup manual).
MIKHMON_IT_PREFIX=mikhmon-it
